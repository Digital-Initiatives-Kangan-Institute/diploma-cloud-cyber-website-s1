---
/**
 * Intranet-zone header. Distinct from PublicHeader:
 *  - No public marketing nav (Study / About / Locations / Apply / Contact)
 *  - Sign-in CTA replaced with a Log-out button that returns to /sign-in
 *  - Slightly denser feel than the public header (less padding)
 *
 * The section nav (ICT / Policies / Projects / Reference / Templates) is not
 * here yet — that gets added once intranet IA decisions are settled and the
 * section content starts landing. Logo still routes to the public homepage
 * for now; once intranet has a proper landing page with content, the logo
 * link can switch to /intranet/.
 */

import LogoPlaceholder from './LogoPlaceholder.astro';
---

<header class="intranet-header">
  <div class="intranet-header-inner">
    <LogoPlaceholder />
    <a href="/sign-in" class="logout-button">Log out</a>
  </div>
</header>

<style>
  .intranet-header {
    border-bottom: var(--border-1);
    background-color: var(--color-bg);
  }
  .intranet-header-inner {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: var(--space-3) var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }
  .logout-button {
    background-color: transparent;
    color: var(--color-primary);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-sm);
    font-weight: var(--weight-medium);
    font-size: var(--font-size-small);
    transition: background-color var(--transition-fast), color var(--transition-fast);
    white-space: nowrap;
  }
  .logout-button:hover,
  .logout-button:focus-visible {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }
</style>
