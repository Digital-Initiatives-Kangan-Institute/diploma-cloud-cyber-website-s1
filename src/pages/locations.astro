---
import PublicLayout from '../layouts/PublicLayout.astro';
import SiteImage from '../components/SiteImage.astro';
---

<PublicLayout
  title="Locations"
  description="YAT College operates from a single Cremorne campus in Melbourne's inner east."
>
  <h1>Cremorne campus</h1>

  <p class="lede">
    YAT College operates from a single campus in Cremorne, in Melbourne's inner
    east. The campus houses all teaching, administration, ICT, and student
    services functions in one location.
  </p>

  <SiteImage
    src="/images/site/locations-hero.jpg"
    alt="The YAT College Cremorne campus seen from the street, with its main entrance and light footpath activity."
    ratio="21/9"
  />

  <section class="campus-block">
    <h2>Address</h2>
    <address class="campus-address">
      YAT College — Cremorne Campus<br />
      175 Cremorne Street<br />
      Cremorne VIC 3121<br />
      Australia
    </address>
  </section>

  <section class="campus-block">
    <h2>Getting here</h2>
    <div class="travel-grid">
      <article class="travel-card">
        <h3>Public transport</h3>
        <p>
          Cremorne is well served by <strong>Richmond station</strong>
          (Glenferrie line and most regional / V/Line services) and tram routes
          along <strong>Swan Street</strong> and <strong>Church Street</strong>.
        </p>
      </article>
      <article class="travel-card">
        <h3>Parking</h3>
        <p>
          On-street parking in Cremorne is limited. Staff and visitor parking
          is available in the campus precinct on request — please contact
          reception ahead of your visit.
        </p>
      </article>
      <article class="travel-card">
        <h3>Accessibility</h3>
        <p>
          The campus is accessible from the Cremorne Street entrance.
          Accessibility details are available on request — please contact
          reception in advance of your visit.
        </p>
      </article>
    </div>
  </section>

  <section class="campus-block">
    <h2>On campus</h2>
    <div class="facilities-grid">
      <article class="facility-card">
        <SiteImage
          src="/images/site/locations-teaching.jpg"
          alt="Adult learners mid-class in a YAT vocational training room."
          ratio="4/3"
        />
        <h3>Teaching spaces</h3>
        <p>Trade workshops, IT and cyber labs, simulated health environments, hospitality kitchens, business and education classrooms.</p>
      </article>
      <article class="facility-card">
        <SiteImage
          src="/images/site/locations-services.jpg"
          alt="A student being helped at the YAT student-services reception desk."
          ratio="4/3"
        />
        <h3>Student services</h3>
        <p>Enrolment, admissions, student support, careers guidance, and the on-campus library.</p>
      </article>
      <article class="facility-card">
        <SiteImage
          src="/images/site/locations-common.jpg"
          alt="Adult learners working together in an informal campus break-out space."
          ratio="4/3"
        />
        <h3>Common spaces</h3>
        <p>Break-out spaces for study and group work, plus a small campus café.</p>
      </article>
    </div>
  </section>

  <section class="campus-block">
    <h2>Contact reception</h2>
    <p>
      Reception is open weekdays during teaching hours. Phone and email details
      are on our <a href="/contact">contact page</a>.
    </p>
  </section>
</PublicLayout>

<style>
  .lede {
    font-size: 1.25rem;
    line-height: var(--leading-snug);
    max-width: var(--content-max-width);
    margin-bottom: var(--space-6);
  }
  .campus-block {
    margin: var(--space-8) 0;
  }
  .campus-block h2 {
    font-size: var(--font-size-h2);
    margin-bottom: var(--space-4);
  }
  .campus-address {
    font-style: normal;
    font-size: 1.125rem;
    line-height: var(--leading-snug);
    padding: var(--space-4) var(--space-5);
    background-color: var(--color-surface);
    border: var(--border-1);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-primary);
    display: inline-block;
  }
  .travel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-4);
  }
  .travel-card {
    padding: var(--space-4);
    background-color: var(--color-surface);
    border: var(--border-1);
    border-radius: var(--radius-md);
  }
  .travel-card h3 {
    font-size: var(--font-size-h3);
    margin-bottom: var(--space-2);
  }
  .travel-card p {
    font-size: var(--font-size-small);
    line-height: var(--leading-snug);
  }
  .facilities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-5);
  }
  .facility-card h3 {
    font-size: var(--font-size-h3);
    margin: var(--space-3) 0 var(--space-2);
  }
  .facility-card p {
    font-size: var(--font-size-small);
    line-height: var(--leading-snug);
  }
</style>
