---
import PublicLayout from '../layouts/PublicLayout.astro';
---

<PublicLayout
  title="Contact"
  description="Contact YAT College — Cremorne campus address, phone, email, and contact form."
>
  <h1>Contact us</h1>

  <p class="lede">
    Get in touch with our admissions team, student services, or campus
    reception. We respond to enquiries within two working days.
  </p>

  <div class="contact-grid">
    <section class="contact-details">
      <h2>Contact details</h2>

      <dl class="details-list">
        <dt>Address</dt>
        <dd>
          YAT College — Cremorne Campus<br />
          175 Cremorne Street<br />
          Cremorne VIC 3121
        </dd>

        <dt>Phone</dt>
        <dd>
          <a href="tel:+61395553485">(03) 9555-3485</a>
          <span class="fake-note">This number is fictional and not connected.</span>
        </dd>

        <dt>Email</dt>
        <dd>
          <a href="mailto:info@yat.timbaird.com">info@yat.timbaird.com</a>
          <span class="fake-note">This address is fictional and not monitored.</span>
        </dd>

        <dt>Reception hours</dt>
        <dd>
          Monday – Friday, 8:30 am – 5:00 pm<br />
          Closed weekends and public holidays
        </dd>
      </dl>

      <p class="map-note">
        <a href="/locations">Getting here</a> — public transport, parking, and
        accessibility information.
      </p>
    </section>

    <section class="contact-form">
      <h2>Send us a message</h2>
      <form method="post" autocomplete="off">
        <div class="field">
          <label for="name">Your name</label>
          <input type="text" id="name" name="name" required />
        </div>
        <div class="field">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="field">
          <label for="topic">What are you contacting us about?</label>
          <select id="topic" name="topic">
            <option>Course information</option>
            <option>How to enrol</option>
            <option>Fees and funding</option>
            <option>Student services (current students)</option>
            <option>Industry / employer enquiry</option>
            <option>Other</option>
          </select>
        </div>
        <div class="field">
          <label for="message">Your message</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>
        <button type="submit">Send message</button>
        <p class="form-note">
          <em>This form is part of a simulated environment — submissions are not
          received, stored, or actioned.</em>
        </p>
      </form>
    </section>
  </div>
</PublicLayout>

<style>
  .lede {
    font-size: 1.25rem;
    line-height: var(--leading-snug);
    max-width: var(--content-max-width);
    margin-bottom: var(--space-6);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.25fr;
    gap: var(--space-8);
    margin-top: var(--space-6);
  }
  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
  h2 {
    font-size: var(--font-size-h3);
    margin-bottom: var(--space-4);
  }
  .details-list {
    margin: 0;
  }
  .details-list dt {
    font-size: var(--font-size-caption);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-top: var(--space-4);
    margin-bottom: var(--space-1);
  }
  .details-list dd {
    margin-left: 0;
    line-height: var(--leading-snug);
  }
  .content-stub-inline {
    background-color: var(--color-surface);
    border-left: 3px solid var(--color-highlight);
    padding: var(--space-2) var(--space-3);
    display: inline-block;
  }
  .fake-note {
    display: block;
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: var(--space-1);
  }
  .map-note {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: var(--border-1);
    font-size: var(--font-size-small);
  }
  .contact-form form {
    background-color: var(--color-surface);
    padding: var(--space-5);
    border: var(--border-1);
    border-radius: var(--radius-md);
  }
  .field {
    margin-bottom: var(--space-4);
  }
  .field label {
    display: block;
    font-size: var(--font-size-small);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-1);
  }
  .field input, .field textarea, .field select {
    width: 100%;
    padding: var(--space-2) var(--space-3);
    font: inherit;
    border: var(--border-1);
    border-radius: var(--radius-sm);
    background-color: var(--color-bg);
    color: var(--color-text);
  }
  .field input:focus, .field textarea:focus, .field select:focus {
    outline: var(--focus-ring);
    outline-offset: var(--focus-offset);
    border-color: var(--color-primary);
  }
  button[type="submit"] {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    border: none;
    padding: var(--space-3) var(--space-5);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-fast);
  }
  button[type="submit"]:hover {
    background-color: #15464a;
  }
  .form-note {
    margin-top: var(--space-3);
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
  }
</style>
