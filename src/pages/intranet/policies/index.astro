---
import IntranetLayout from '../../../layouts/IntranetLayout.astro';

const policies = [
  { title: 'Change management procedure', href: '/intranet/policies/change-management', summary: 'How material changes to YAT systems are proposed, reviewed, and approved.' },
  { title: 'User access policy',           href: '/intranet/policies/user-access',       summary: 'Provisioning, modification, and revocation of access to YAT systems and data.' },
  { title: 'Acceptable use policy',         href: '/intranet/policies/acceptable-use',   summary: 'Acceptable conduct when using YAT IT systems, networks, and services.' },
  { title: 'Workplace health and safety policy', href: '/intranet/policies/whs',         summary: 'YAT WHS obligations, hazard reporting, and incident procedures.' },
  { title: 'Privacy policy',                href: '/intranet/policies/privacy',          summary: 'How YAT handles personal information of students, staff, and contractors.' },
  { title: 'Backup retention policy',       href: '/intranet/policies/backup-retention', summary: 'Backup schedules, retention windows, and recovery testing arrangements.' },
  { title: 'Security and incident response', href: '/intranet/policies/security-incident', summary: 'Response procedures for cyber security incidents and data breaches.' },
  { title: 'Records management policy',     href: '/intranet/policies/records-management', summary: 'Records classification, retention, secure destruction, and audit obligations.', placeholder: true },
];
---

<IntranetLayout
  title="Policies & procedures"
  description="YAT College policies and operational procedures — change management, user access, privacy, WHS, security incident response, records management, and more."
>
  <p class="breadcrumbs"><a href="/intranet/">Intranet</a> · Policies &amp; procedures</p>

  <h1>Policies &amp; procedures</h1>

  <p class="lede">
    The policy and procedure suite governing YAT operations. All policies are
    reviewed annually; the latest approved version is the one to use.
  </p>

  <ul class="item-list">
    {policies.map(policy => (
      <li>
        <h2><a href={policy.href}>{policy.title}</a></h2>
        <p>{policy.summary}</p>
        {policy.placeholder && <span class="item-stub">Placeholder &mdash; full content still to be drafted</span>}
      </li>
    ))}
  </ul>

  <p class="back-link">
    <a href="/intranet/">← Back to Intranet home</a>
  </p>
</IntranetLayout>

<style>
  .breadcrumbs {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }
  .breadcrumbs a {
    color: var(--color-text-muted);
  }
  .lede {
    font-size: 1.125rem;
    line-height: var(--leading-snug);
    max-width: var(--content-max-width);
    margin-bottom: var(--space-6);
  }
  .item-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .item-list li {
    padding: var(--space-4) 0;
    border-bottom: var(--border-1);
  }
  .item-list h2 {
    font-size: var(--font-size-h3);
    margin-bottom: var(--space-1);
  }
  .item-list p {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-2);
    max-width: var(--content-max-width);
  }
  .item-stub {
    display: inline-block;
    font-size: var(--font-size-caption);
    color: var(--color-accent);
    font-style: italic;
  }
  .back-link {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: var(--border-1);
    font-size: var(--font-size-small);
  }
</style>
