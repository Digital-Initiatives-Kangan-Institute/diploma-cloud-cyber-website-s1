---
/**
 * Per-state ICT landing — lists ICT operational documents that appear in
 * the current state, sorted by frontmatter `order` (lower first). For docs
 * with a `yearOffset`, the actual year is computed at build time and
 * prepended to the displayed title.
 */

import IntranetLayout from '../../../../layouts/IntranetLayout.astro';
import { getCollection } from 'astro:content';
import { STATES } from '../../../../config/states';

export function getStaticPaths() {
  return STATES.map(s => ({
    params: { state: s.slug },
    props: { state: s },
  }));
}

const { state } = Astro.props;
const base = `/intranet/${state.slug}`;
const currentYear = new Date().getFullYear();

const allItems = await getCollection('ict');
const items = allItems
  .filter(d => d.data.appearsIn.includes(state.slug))
  .sort((a, b) => {
    const orderA = a.data.order ?? Number.MAX_SAFE_INTEGER;
    const orderB = b.data.order ?? Number.MAX_SAFE_INTEGER;
    if (orderA !== orderB) return orderA - orderB;
    return a.data.title.localeCompare(b.data.title);
  })
  .map(d => {
    const displayTitle = d.data.yearOffset !== undefined
      ? `${currentYear + d.data.yearOffset} ${d.data.title}`
      : d.data.title;
    return {
      slug: d.id,
      displayTitle,
      description: d.data.description,
      placeholder: d.data.placeholder,
    };
  });
---

<IntranetLayout
  title="ICT"
  description={`YAT College ICT department — ${state.fullLabel}.`}
  breadcrumb={[
    { text: 'Intranet', href: `${base}/` },
    { text: 'ICT' },
  ]}
>
  <h1>ICT</h1>
  <p class="state-notation">Intranet state for {state.fullLabel}</p>

  <p class="lede">
    Current-state operational reference for the YAT ICT department.
  </p>

  {items.length > 0 ? (
    <ul class="item-list">
      {items.map(item => (
        <li>
          <h2><a href={`${base}/ict/${item.slug}`}>{item.displayTitle}</a></h2>
          <p>{item.description}</p>
          {item.placeholder && (
            <span class="item-stub">Placeholder &mdash; full content still to be drafted</span>
          )}
        </li>
      ))}
    </ul>
  ) : (
    <div class="content-stub">
      <p>
        ICT documents will appear here as they are migrated. Several are
        expected to change content between project states (environment overview,
        network diagram, server status, hardware inventory, backup-recovery
        procedure) — each will appear in the form appropriate to the current
        state.
      </p>
    </div>
  )}
</IntranetLayout>

<style>
  .state-notation {
    font-size: var(--font-size-small);
    font-style: italic;
    color: var(--color-text-muted);
    margin-top: calc(var(--space-2) * -1);
    margin-bottom: var(--space-5);
  }
  .lede {
    font-size: 1.125rem;
    line-height: var(--leading-snug);
    max-width: var(--content-max-width);
    margin-bottom: var(--space-5);
  }
  .item-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .item-list li {
    padding: var(--space-4) 0;
    border-bottom: var(--border-1);
  }
  .item-list h2 {
    font-size: var(--font-size-h3);
    margin-bottom: var(--space-1);
  }
  .item-list p {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-2);
    max-width: var(--content-max-width);
  }
  .item-stub {
    display: inline-block;
    font-size: var(--font-size-caption);
    color: var(--color-accent);
    font-style: italic;
  }
  .content-stub {
    padding: var(--space-5);
    background-color: var(--color-surface);
    border: var(--border-1);
    border-left: 4px solid var(--color-highlight);
    border-radius: var(--radius-sm);
    margin: var(--space-5) 0;
  }
  .content-stub p { line-height: var(--leading-snug); margin: 0; max-width: var(--content-max-width); }
</style>
