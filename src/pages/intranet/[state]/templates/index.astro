---
/**
 * Per-state templates landing — placeholder until template documents are
 * migrated. Templates are eventually served as static .docx / .pptx files
 * from /public/downloads/ with metadata + a download link per item here.
 */

import IntranetLayout from '../../../../layouts/IntranetLayout.astro';
import { STATES } from '../../../../config/states';

export function getStaticPaths() {
  return STATES.map(s => ({
    params: { state: s.slug },
    props: { state: s },
  }));
}

const { state } = Astro.props;
const base = `/intranet/${state.slug}`;

// Available templates (static files under /public/templates/). Add entries here
// as further templates are finalised.
const templates = [
  {
    title: 'Business Case',
    description:
      'The YAT business case template — cover sheet, table of contents, and every section with built-in guidance, ready to complete.',
    href: '/templates/YAT-Business-Case-Template.docx',
    format: 'DOCX',
  },
  {
    title: 'Business Case Presentation',
    description:
      'The YAT board-presentation deck template — title, agenda, and every section with built-in guidance, ready to complete.',
    href: '/templates/YAT-Business-Case-Deck-Template.pptx',
    format: 'PPTX',
  },
];
---

<IntranetLayout
  title="Templates"
  description={`YAT document templates — ${state.fullLabel}.`}
  breadcrumb={[
    { text: 'Intranet', href: `${base}/` },
    { text: 'Templates' },
  ]}
>
  <h1>Templates</h1>
  <p class="state-notation">Intranet state for {state.fullLabel}</p>

  <p class="lede">
    Document templates used across YAT projects and engagements. Download the
    relevant template, complete it for your work, and submit through your
    engagement's normal acceptance process.
  </p>

  <ul class="template-list">
    {templates.map(t => (
      <li>
        <div class="template-head">
          <h3>{t.title}</h3>
          <span class="format-badge">{t.format}</span>
        </div>
        <p>{t.description}</p>
        <a class="download-link" href={t.href} download>Download template ({t.format})</a>
      </li>
    ))}
  </ul>
</IntranetLayout>

<style>
  .state-notation {
    font-size: var(--font-size-small);
    font-style: italic;
    color: var(--color-text-muted);
    margin-top: calc(var(--space-2) * -1);
    margin-bottom: var(--space-5);
  }
  .lede {
    font-size: 1.125rem;
    line-height: var(--leading-snug);
    max-width: var(--content-max-width);
    margin-bottom: var(--space-5);
  }
  .template-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: var(--content-max-width);
  }
  .template-list li {
    padding: var(--space-4) 0;
    border-bottom: var(--border-1);
  }
  .template-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }
  .template-head h3 {
    font-size: var(--font-size-h3);
    margin: 0 0 var(--space-1) 0;
  }
  .format-badge {
    font-size: var(--font-size-caption);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    border: var(--border-1);
    border-radius: var(--radius-sm);
    padding: 0 var(--space-2);
  }
  .template-list p {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-2) 0;
  }
  .download-link {
    display: inline-block;
    font-weight: var(--weight-semibold);
    color: var(--color-accent);
  }
</style>
