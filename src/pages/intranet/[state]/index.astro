---
/**
 * Per-state intranet landing — dynamic route generates one page per real
 * state defined in src/config/states.ts. State slug is the URL segment,
 * e.g. /intranet/s1-cl1-at1/.
 *
 * All category links from this landing stay in-state (i.e. lead to other
 * URLs under /intranet/{state}/...), so the user remains "in their state"
 * throughout intranet navigation.
 */

import IntranetLayout from '../../../layouts/IntranetLayout.astro';
import { STATES } from '../../../config/states';

export function getStaticPaths() {
  return STATES.map(s => ({
    params: { state: s.slug },
    props: { state: s },
  }));
}

const { state } = Astro.props;
const base = `/intranet/${state.slug}`;
---

<IntranetLayout
  title="Home"
  description={`YAT College staff intranet — ${state.fullLabel}.`}
>
  <h1>Staff Intranet</h1>
  <p class="state-notation">Intranet state for {state.fullLabel}</p>

  <p class="lede">
    Operational reference, policies, projects, and document templates for
    YAT staff and engaged contractors. Choose a section to continue.
  </p>

  <div class="content-stub">
    <ul>
      <li><a href={`${base}/policies/`}><strong>Policies &amp; procedures</strong></a> — change management, user access, acceptable use, WHS, privacy, backup retention, security incident response, records management</li>
      <li><a href={`${base}/reference/`}><strong>Reference &amp; standards</strong></a> — industry standards, legislative requirements, reference architectures</li>
      <li><a href={`${base}/ict/`}><strong>ICT</strong></a> — environment overview, network diagrams, server status, hardware inventory, backup-recovery procedures</li>
      <li><a href={`${base}/projects/`}><strong>Projects</strong></a> — current and past consulting engagements, including the LMS cloud migration</li>
      <li><a href={`${base}/templates/`}><strong>Templates</strong></a> — downloadable document templates (.docx, .pptx)</li>
    </ul>
  </div>
</IntranetLayout>

<style>
  .state-notation {
    font-size: var(--font-size-small);
    font-style: italic;
    color: var(--color-text-muted);
    margin-top: calc(var(--space-2) * -1);
    margin-bottom: var(--space-5);
  }
  .lede {
    font-size: 1.25rem;
    line-height: var(--leading-snug);
    max-width: var(--content-max-width);
    margin-bottom: var(--space-6);
  }
  .content-stub {
    padding: var(--space-5);
    background-color: var(--color-surface);
    border: var(--border-1);
    border-left: 4px solid var(--color-highlight);
    border-radius: var(--radius-sm);
    margin: var(--space-5) 0;
  }
  .content-stub ul {
    margin-top: var(--space-3);
  }
  .content-stub li {
    padding: var(--space-2) 0;
    line-height: var(--leading-snug);
  }
</style>
