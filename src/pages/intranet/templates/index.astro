---
import IntranetLayout from '../../../layouts/IntranetLayout.astro';

const templates = [
  { title: 'Business case',                  format: 'docx', summary: 'Business case template — used for project investment proposals to YAT leadership.' },
  { title: 'Business case presentation',     format: 'pptx', summary: 'Companion deck for board / leadership presentations of a business case.' },
  { title: 'Feedback record',                format: 'docx', summary: 'Structured feedback capture form for post-deliverable reviews and engagement closures.' },
  { title: 'Deployment report',              format: 'docx', summary: 'Cloud infrastructure deployment report — used to document and hand over completed build work.' },
  { title: 'High-availability design',       format: 'docx', summary: 'HA architecture design template — fault tolerance analysis, target SLAs, design decisions, simulation plan.' },
  { title: 'HA deployment report',           format: 'docx', summary: 'High-availability deployment report — used after HA hardening is complete, for sign-off via change management.' },
];
---

<IntranetLayout
  title="Templates"
  description="YAT College document templates — business case, deployment report, HA design, feedback record, and more."
>
  <p class="breadcrumbs"><a href="/intranet/">Intranet</a> · Templates</p>

  <h1>Templates</h1>

  <p class="lede">
    Document templates used across YAT projects and engagements. Download the
    relevant template, complete it for your work, and submit through your
    engagement's normal acceptance process.
  </p>

  <ul class="item-list">
    {templates.map(template => (
      <li>
        <h2>
          {template.title}
          <span class="template-format">{template.format.toUpperCase()}</span>
        </h2>
        <p>{template.summary}</p>
        <span class="item-stub">Template &mdash; file to be uploaded</span>
      </li>
    ))}
  </ul>

  <p class="back-link">
    <a href="/intranet/">← Back to Intranet home</a>
  </p>
</IntranetLayout>

<style>
  .breadcrumbs {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }
  .breadcrumbs a {
    color: var(--color-text-muted);
  }
  .lede {
    font-size: 1.125rem;
    line-height: var(--leading-snug);
    max-width: var(--content-max-width);
    margin-bottom: var(--space-6);
  }
  .item-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .item-list li {
    padding: var(--space-4) 0;
    border-bottom: var(--border-1);
  }
  .item-list h2 {
    font-size: var(--font-size-h3);
    margin-bottom: var(--space-1);
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .template-format {
    font-size: var(--font-size-caption);
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-weight: var(--weight-regular);
    background-color: var(--color-bg);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }
  .item-list p {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-2);
    max-width: var(--content-max-width);
  }
  .item-stub {
    display: inline-block;
    font-size: var(--font-size-caption);
    color: var(--color-accent);
    font-style: italic;
  }
  .back-link {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: var(--border-1);
    font-size: var(--font-size-small);
  }
</style>
