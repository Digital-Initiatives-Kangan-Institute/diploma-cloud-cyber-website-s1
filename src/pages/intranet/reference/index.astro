---
import IntranetLayout from '../../../layouts/IntranetLayout.astro';

const items = [
  { title: 'Industry standards',     href: '/intranet/reference/industry-standards',     summary: 'Australian and international standards relevant to YAT ICT operations and engagement work.' },
  { title: 'Legislative requirements', href: '/intranet/reference/legislative',           summary: 'Federal and Victorian legislation that bears on YAT ICT operations — privacy, records, education sector, cyber security.' },
  { title: 'Reference architectures', href: '/intranet/reference/reference-architectures', summary: 'Architecture patterns and reference designs available for staff and consultants when planning ICT changes.' },
];
---

<IntranetLayout
  title="Reference & standards"
  description="YAT reference materials — industry standards, legislative requirements, and architecture references for ICT operations."
>
  <p class="breadcrumbs"><a href="/intranet/">Intranet</a> · Reference &amp; standards</p>

  <h1>Reference &amp; standards</h1>

  <p class="lede">
    Compliance, legislative, and architectural reference material for staff
    and engaged contractors. Items here apply across YAT ICT operations
    generally, not to any single project.
  </p>

  <ul class="item-list">
    {items.map(item => (
      <li>
        <h2><a href={item.href}>{item.title}</a></h2>
        <p>{item.summary}</p>
      </li>
    ))}
  </ul>

  <p class="back-link">
    <a href="/intranet/">← Back to Intranet home</a>
  </p>
</IntranetLayout>

<style>
  .breadcrumbs {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }
  .breadcrumbs a {
    color: var(--color-text-muted);
  }
  .lede {
    font-size: 1.125rem;
    line-height: var(--leading-snug);
    max-width: var(--content-max-width);
    margin-bottom: var(--space-6);
  }
  .item-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .item-list li {
    padding: var(--space-4) 0;
    border-bottom: var(--border-1);
  }
  .item-list h2 {
    font-size: var(--font-size-h3);
    margin-bottom: var(--space-1);
  }
  .item-list p {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-2);
    max-width: var(--content-max-width);
  }
  .item-stub {
    display: inline-block;
    font-size: var(--font-size-caption);
    color: var(--color-accent);
    font-style: italic;
  }
  .back-link {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: var(--border-1);
    font-size: var(--font-size-small);
  }
</style>
