---
/**
 * Intranet entry — state picker. The user lands here after the mock SSO and
 * chooses which assessment-task state of the intranet to view.
 *
 * Structure: Semester → Cluster → AT. Real (designed + built) ATs are
 * clickable links to /intranet/{slug}/. Future clusters / ATs not yet
 * designed appear as visible-but-not-clickable placeholders so the
 * eventual shape of the course is on-screen from day one (anticipated
 * ~7 clusters / ~20 ATs total per Tim).
 *
 * Source of truth for what's real vs placeholder: src/config/states.ts.
 */

import IntranetLayout from '../../layouts/IntranetLayout.astro';
import { getGroupedStructure } from '../../config/states';

const groups = getGroupedStructure();
---

<IntranetLayout
  title="Select your state"
  description="YAT College staff intranet — choose your current assessment task to view the relevant version of the intranet."
>
  <h1>Staff Intranet</h1>

  <p class="lede">
    The state of the intranet depends on how far through the course you are.
    Please select which assessment task you are undertaking to see the
    relevant version of the intranet.
  </p>

  <div class="picker">
    {groups.map(semester => (
      <section class="semester">
        <h2>{semester.semesterLabel}</h2>
        {semester.clusters.map(cluster => (
          <article class="cluster">
            <h3>
              Cluster {cluster.clusterNumber} — {cluster.clusterLabel}
            </h3>
            <ul class="at-list">
              {cluster.ats.map(at => (
                at.kind === 'real' ? (
                  <li class="at-real">
                    <a href={`/intranet/${at.state.slug}/`}>
                      <span class="at-code">{at.state.slug.toUpperCase()}</span>
                      <span class="at-name">AT{at.state.atNumber}: {at.state.atLabel}</span>
                    </a>
                  </li>
                ) : (
                  <li class="at-placeholder" aria-disabled="true">
                    <span class="at-code">{`S${cluster.semesterNumber}-${cluster.clusterCode}-AT${at.atNumber}`.toLowerCase()}</span>
                    <span class="at-name">AT{at.atNumber}: {at.atLabel}</span>
                    <span class="at-status">not yet available</span>
                  </li>
                )
              ))}
            </ul>
          </article>
        ))}
      </section>
    ))}
  </div>
</IntranetLayout>

<style>
  .lede {
    font-size: 1.125rem;
    line-height: var(--leading-snug);
    max-width: var(--content-max-width);
    margin-bottom: var(--space-8);
  }
  .picker {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .semester h2 {
    font-size: var(--font-size-h2);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-2);
    border-bottom: var(--border-1);
  }
  .cluster {
    margin-bottom: var(--space-6);
  }
  .cluster h3 {
    font-size: var(--font-size-h3);
    margin-bottom: var(--space-3);
  }
  .at-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .at-real a, .at-placeholder {
    display: grid;
    grid-template-columns: 9rem 1fr auto;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border: var(--border-1);
    border-radius: var(--radius-sm);
    background-color: var(--color-surface);
    text-decoration: none;
  }
  .at-real a {
    color: var(--color-text);
    transition: border-color var(--transition-fast), transform var(--transition-fast);
  }
  .at-real a:hover, .at-real a:focus-visible {
    border-color: var(--color-primary);
    transform: translateX(2px);
  }
  .at-placeholder {
    color: var(--color-text-muted);
    background-color: transparent;
    border-style: dashed;
    cursor: not-allowed;
  }
  .at-code {
    font-family: var(--font-mono);
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }
  .at-real .at-name {
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }
  .at-placeholder .at-name {
    font-style: italic;
  }
  .at-status {
    font-size: var(--font-size-caption);
    font-style: italic;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .at-real a, .at-placeholder {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
