---
/**
 * Intranet home — section index. Keyword links lead to each top-level
 * section landing (locked top-level categories per scenario/website.md §2.3).
 *
 * Order locked by Tim 2026-05-26:
 *   1. Policies & procedures
 *   2. Reference & standards
 *   3. ICT
 *   4. Projects
 *   5. Templates
 */

import IntranetLayout from '../../layouts/IntranetLayout.astro';
---

<IntranetLayout
  title="Home"
  description="YAT College staff intranet — section directory."
>
  <h1>Staff Intranet</h1>

  <p class="lede">
    Operational reference, policies, projects, and document templates for
    YAT staff and engaged contractors. Choose a section to continue.
  </p>

  <div class="content-stub">
    <ul>
      <li><a href="/intranet/policies/"><strong>Policies &amp; procedures</strong></a> — change management, user access, acceptable use, WHS, privacy, backup retention, security incident response, records management</li>
      <li><a href="/intranet/reference/"><strong>Reference &amp; standards</strong></a> — industry standards, legislative requirements, reference architectures</li>
      <li><a href="/intranet/ict/"><strong>ICT</strong></a> — environment overview, network diagrams, server status, hardware inventory, backup-recovery procedures</li>
      <li><a href="/intranet/projects/"><strong>Projects</strong></a> — current and past consulting engagements, including the LMS cloud migration</li>
      <li><a href="/intranet/templates/"><strong>Templates</strong></a> — downloadable document templates (.docx, .pptx)</li>
    </ul>
  </div>
</IntranetLayout>

<style>
  .lede {
    font-size: 1.25rem;
    line-height: var(--leading-snug);
    max-width: var(--content-max-width);
    margin-bottom: var(--space-6);
  }
  .content-stub {
    padding: var(--space-5);
    background-color: var(--color-surface);
    border: var(--border-1);
    border-left: 4px solid var(--color-highlight);
    border-radius: var(--radius-sm);
    margin: var(--space-5) 0;
  }
  .content-stub ul {
    margin-top: var(--space-3);
  }
  .content-stub li {
    padding: var(--space-2) 0;
    line-height: var(--leading-snug);
  }
</style>
