<mxfile host="app.diagrams.net" modified="2026-06-08T00:00:00.000Z" agent="YAT scenario authoring" version="22.0.0" type="device">
  <diagram id="acct-baseline-singleaz" name="YAT — Ledgerline (Accounting) baseline, single-AZ">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1440" pageHeight="1020" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="YAT Network Topology — Ledgerline (Accounting &amp; Office Administration) in AWS, single-AZ baseline; internal, staff-only over the campus VPN" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1360" height="30" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="Legend&#xa;━━━ Staff access: campus → Site-to-Site VPN → internal ALB (HTTPS:443)&#xa;┄┄┄ Egress only: EC2 → NAT gateway → internet gateway → internet (patching). No inbound path to the app.&#xa;┄┄┄ AD / LDAPS authentication + management over the VPN&#xa;Security groups: sg-alb → sg-app → sg-db (least-privilege, chained tier-to-tier)&#xa;Dashed boxes = AWS subnets (single-AZ baseline; matching -b subnets in a second AZ added when HA-hardened)&#xa;* EC2 instance type = implementer decision" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="58" width="640" height="130" as="geometry" />
        </mxCell>

        <mxCell id="internet" value="Internet&#xa;(egress only — patching)" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#546E7A;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="760" y="62" width="170" height="84" as="geometry" />
        </mxCell>

        <mxCell id="s2svpn" value="Site-to-Site VPN&#xa;Campus ↔ AWS&#xa;staff access + AD/LDAPS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="200" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- ===== Campus (on-premises) ===== -->
        <mxCell id="campuszone" value="Campus Network (on-premises)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="470" height="300" as="geometry" />
        </mxCell>
        <mxCell id="campussw" value="Campus Switch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2DFDB;strokeColor=#00695C;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="130" y="340" width="280" height="38" as="geometry" />
        </mxCell>
        <mxCell id="dc" value="Domain Controller&#xa;AD / DNS (LDAPS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#00695C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="405" width="190" height="58" as="geometry" />
        </mxCell>
        <mxCell id="bastion" value="MTS Bastion (admin)&#xa;RDP 3389 — implementer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="405" width="190" height="58" as="geometry" />
        </mxCell>
        <mxCell id="staff" value="Finance &amp; Office Administration staff&#xa;Ledgerline users (AD-joined desktops)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#00695C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="495" width="400" height="58" as="geometry" />
        </mxCell>

        <mxCell id="e_sw_dc" style="endArrow=none;html=1;rounded=0;strokeColor=#00695C;" edge="1" parent="1" source="campussw" target="dc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_sw_bastion" style="endArrow=none;html=1;rounded=0;strokeColor=#00695C;" edge="1" parent="1" source="campussw" target="bastion"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_sw_staff" style="endArrow=none;html=1;rounded=0;strokeColor=#00695C;" edge="1" parent="1" source="campussw" target="staff"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_sw_s2s" style="endArrow=none;html=1;rounded=0;strokeColor=#6A1B9A;strokeWidth=2;" edge="1" parent="1" source="campussw" target="s2svpn"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== AWS ===== -->
        <mxCell id="awsregion" value="AWS Region — ap-southeast-2 (Sydney)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="300" width="820" height="660" as="geometry" />
        </mxCell>
        <mxCell id="vpc" value="VPC  10.0.0.0/16   ·   DNS resolution + VPC flow logs enabled" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#0D47A1;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="585" y="356" width="770" height="580" as="geometry" />
        </mxCell>

        <mxCell id="igw" value="Internet Gateway&#xa;(egress only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="615" y="394" width="190" height="46" as="geometry" />
        </mxCell>
        <mxCell id="vgw" value="VPN Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1140" y="394" width="190" height="46" as="geometry" />
        </mxCell>

        <mxCell id="e_int_igw" style="endArrow=classic;html=1;rounded=0;strokeColor=#BF360C;dashed=1;" edge="1" parent="1" source="igw" target="internet">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="845" y="275" /></Array>
          </mxGeometry>
