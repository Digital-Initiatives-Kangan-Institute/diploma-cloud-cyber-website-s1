        <!-- public-egress -->
        <mxCell id="pubsub" value="Public Subnet  public-egress-a&#xa;10.0.1.0/24  (ap-southeast-2a)  ·  route → IGW" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="615" y="466" width="710" height="88" as="geometry" />
        </mxCell>
        <mxCell id="natgw" value="NAT Gateway&#xa;(outbound patching only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="645" y="496" width="240" height="48" as="geometry" />
        </mxCell>

        <!-- private-app -->
        <mxCell id="appsub" value="Private Subnet  private-app-a&#xa;10.0.11.0/24  (ap-southeast-2a)  ·  route → NAT" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="615" y="578" width="710" height="180" as="geometry" />
        </mxCell>
        <mxCell id="alb" value="Internal Application Load Balancer&#xa;HTTPS:443 — staff-only, via the VPN&#xa;sg-alb" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7B1FA2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="645" y="626" width="300" height="74" as="geometry" />
        </mxCell>
        <mxCell id="ec2" value="EC2 — Ledgerline application&#xa;Windows Server 2016 (m6i.large*)&#xa;Auto Scaling Group (min 1 / max 2)&#xa;⚠ single-AZ baseline — not HA&#xa;sg-app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7B1FA2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="980" y="618" width="320" height="120" as="geometry" />
        </mxCell>

        <!-- private-data -->
        <mxCell id="datasub" value="Private Subnet  private-data-a&#xa;10.0.21.0/24  (ap-southeast-2a)  ·  no internet route" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="615" y="782" width="710" height="110" as="geometry" />
        </mxCell>
        <mxCell id="rds" value="Amazon RDS for SQL Server&#xa;single-AZ baseline  ⚠ not HA&#xa;sg-db" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C62828;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="645" y="816" width="330" height="64" as="geometry" />
        </mxCell>

        <!-- flows -->
        <mxCell id="e_vgw_alb" value="staff HTTPS:443" style="endArrow=classic;html=1;rounded=0;strokeColor=#6A1B9A;fontSize=10;" edge="1" parent="1" source="vgw" target="alb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_alb_ec2" value="443" style="endArrow=classic;html=1;rounded=0;strokeColor=#7B1FA2;fontSize=10;" edge="1" parent="1" source="alb" target="ec2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ec2_rds" value="SQL 1433" style="endArrow=classic;html=1;rounded=0;strokeColor=#C62828;fontSize=10;" edge="1" parent="1" source="ec2" target="rds"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ec2_nat" value="egress" style="endArrow=classic;html=1;rounded=0;strokeColor=#F9A825;dashed=1;fontSize=10;" edge="1" parent="1" source="ec2" target="natgw"><mxGeometry relative="1" as="geometry" /></mxCell>
